# Copy to .env and edit: cp .env.example .env

# --- SQLite single-node (docker-compose.yml only) ---
TZ=Asia/Shanghai
NEW_API_PORT_MAPPING=3000:3000
# Safer when exposing only via Caddy/Tunnel on the same host:
# NEW_API_PORT_MAPPING=127.0.0.1:3000:3000

ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=new-api-node-1

# Optional single-node hints (uncomment in docker-compose.yml if needed):
# SESSION_SECRET=replace-with-long-random-string

# --- HTTPS reverse proxy (docker-compose.caddy.yml) ---
# CADDY_DOMAIN=api.example.com
# CADDY_PUBLISH_HTTP=0.0.0.0
# CADDY_PUBLISH_HTTPS=0.0.0.0

# --- Cloudflare Tunnel (docker-compose.tunnel.yml) ---
# CLOUDFLARE_TUNNEL_TOKEN=paste-token-from-zero-trust

# --- Postgres + Redis stack (docker-compose.postgres.yml) ---
# SQL_DSN=postgresql://root:REPLACE_ME@postgres:5432/new-api
# POSTGRES_USER=root
# POSTGRES_PASSWORD=REPLACE_ME
# POSTGRES_DB=new-api
# REDIS_PASSWORD=REPLACE_ME
# REDIS_CONN_STRING=redis://:REPLACE_ME@redis:6379
# SESSION_SECRET=replace-with-long-random-string
# CRYPTO_SECRET=replace-with-long-random-string
