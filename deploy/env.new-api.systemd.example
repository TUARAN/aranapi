# Copy to /etc/new-api.env (chmod 600). Do not commit real secrets.

TZ=Asia/Shanghai
PORT=3000

# Upstream listens on 0.0.0.0:PORT (see main.go). For production, restrict exposure with
# host firewall (allow only 127.0.0.1) or keep this machine off the public Internet and use Tunnel.

# SQLite (default when SQL_DSN unset): ensure WorkingDirectory or explicit path is writable.
# Prefer Postgres/MySQL for production:
# SQL_DSN=postgresql://user:pass@127.0.0.1:5432/new-api
# REDIS_CONN_STRING=redis://:pass@127.0.0.1:6379

SESSION_SECRET=replace-with-long-random-string
# CRYPTO_SECRET=required-when-using-redis-per-upstream-docs

ERROR_LOG_ENABLED=true
NODE_NAME=new-api-prod-1
